# ═════════════════════════════════════════════════════════════════════
#   Anandabazar BDMart — FRONTEND (Next.js) environment variables
# ═════════════════════════════════════════════════════════════════════
# HOW TO USE
#   • Local dev : copy this file to `.env.local` and fill the values.
#   • Vercel    : Project → Settings → Environment Variables → add each one
#                 (for the Production environment). Do NOT commit `.env.local`.
#
# NOTE: every var here is PUBLIC (NEXT_PUBLIC_*) — it ships to the browser.
#       Never put secrets here. The Socket.IO URL for real-time updates is
#       derived automatically from NEXT_PUBLIC_API_URL (its `/api` suffix is
#       stripped), so setting the API URL alone makes real-time work.
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] Backend REST base URL — MUST include the /api suffix.
#   Local : http://localhost:5000/api
#   Prod  : https://your-backend.onrender.com/api      ← your Render backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# [REQUIRED] This site's own public URL (canonical links / sitemap / OG tags).
#   Local : http://localhost:3000
#   Prod  : https://your-client.vercel.app             ← your Vercel URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [optional] Google "Sign in with Google" client id.
# Must match the backend's GOOGLE_CLIENT_ID. Leave blank to hide the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
